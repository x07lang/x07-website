{
  "schema_version": "x07.device.profile@0.1.0",
  "id": "device_ios_dev",
  "v": 1,
  "target": "ios",
  "identity": {
    "display_name": "x07 Field Notes (iOS Dev)",
    "app_id": "org.x07.fieldnotes.ios.dev"
  },
  "version": {
    "version": "0.1.0",
    "build": 1
  },
  "security": {
    "allow_dynamic_code_loading": false
  },
  "ui": {
    "project": "frontend/x07.json",
    "web_ui_profile_id": "web_ui_debug"
  },
  "backend": {
    "mode": "remote_http",
    "base_url": "https://example.invalid",
    "allowed_hosts": ["example.invalid"]
  },
  "capabilities": {
    "network": {
      "mode": "deny_by_default",
      "allow_hosts": []
    },
    "device": {
      "clipboard": true,
      "local_kv": true,
      "notifications": false
    }
  },
  "ios": {
    "bundle_id": "org.x07.fieldnotes.ios.dev",
    "signing_mode": "dev"
  },
  "notes": "Default mobile packaging keeps runtime network denied until a real backend base_url and allowlist are configured in this profile."
}
