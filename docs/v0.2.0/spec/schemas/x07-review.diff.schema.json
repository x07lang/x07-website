{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-review.diff.schema.json",
  "title": "x07.review.diff@0.5.0",
  "description": "Machine-readable semantic diff model emitted by `x07 review diff` (JSON backing model for the HTML intent-level diff viewer).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "from",
    "to",
    "summary",
    "highlights",
    "files",
    "diags"
  ],
  "properties": {
    "schema_version": { "const": "x07.review.diff@0.5.0" },
    "mode": {
      "type": "string",
      "enum": ["project", "ast-only"]
    },
    "from": { "$ref": "#/$defs/snapshot" },
    "to": { "$ref": "#/$defs/snapshot" },
    "summary": { "$ref": "#/$defs/summary" },
    "highlights": { "$ref": "#/$defs/highlights" },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/file_diff" },
      "default": []
    },
    "diags": {
      "type": "array",
      "items": { "$ref": "x07diag.schema.json#/$defs/diagnostic" },
      "default": []
    },
    "meta": { "type": "object", "additionalProperties": true, "default": {} }
  },
  "$defs": {
    "sha256_hex": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "json_value": {
      "description": "Any JSON value.",
      "type": ["null", "boolean", "number", "string", "array", "object"]
    },
    "review_severity": {
      "type": "string",
      "enum": ["info", "warn", "high"]
    },
    "world": {
      "type": "string",
      "enum": [
        "solve-pure",
        "solve-fs",
        "solve-rr",
        "solve-kv",
        "solve-full",
        "run-os",
        "run-os-sandboxed"
      ]
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256_hex"],
      "properties": {
        "kind": { "type": "string", "enum": ["file", "dir"] },
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sha256_hex": {
          "anyOf": [{ "$ref": "#/$defs/sha256_hex" }, { "type": "null" }]
        },
        "note": { "type": "string", "maxLength": 1024, "default": "" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_total",
        "files_changed",
        "modules_changed",
        "decls_added",
        "decls_removed",
        "decls_changed",
        "high_severity_changes",
        "truncated"
      ],
      "properties": {
        "files_total": { "type": "integer", "minimum": 0 },
        "files_changed": { "type": "integer", "minimum": 0 },
        "modules_changed": { "type": "integer", "minimum": 0 },
        "decls_added": { "type": "integer", "minimum": 0 },
        "decls_removed": { "type": "integer", "minimum": 0 },
        "decls_changed": { "type": "integer", "minimum": 0 },
        "high_severity_changes": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" }
      }
    },
    "highlights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_changes",
        "budget_changes",
        "summary_changes",
        "policy_changes",
        "network_policy_changes",
        "capability_changes",
        "proof_changes",
        "assumption_changes",
        "boundedness_changes",
        "operational_entry_changes",
        "recursive_proof_changes",
        "boundary_changes",
        "subset_changes",
        "async_proof_changes",
        "capsule_changes",
        "peer_policy_changes",
        "capsule_network_changes",
        "dependency_closure_changes",
        "runtime_attestation_changes",
        "sandbox_policy_changes"
      ],
      "properties": {
        "world_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/world_change" },
          "default": []
        },
        "budget_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/budget_change" },
          "default": []
        },
        "summary_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "policy_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_change" },
          "default": []
        },
        "network_policy_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "capability_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/capability_change" },
          "default": []
        },
        "proof_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/proof_change" },
          "default": []
        },
        "assumption_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "boundedness_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "operational_entry_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "recursive_proof_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/recursive_proof_change" },
          "default": []
        },
        "boundary_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/boundary_change" },
          "default": []
        },
        "subset_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/subset_change" },
          "default": []
        },
        "async_proof_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/async_proof_change" },
          "default": []
        },
        "capsule_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/capsule_change" },
          "default": []
        },
        "peer_policy_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "capsule_network_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "dependency_closure_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/generic_change" },
          "default": []
        },
        "runtime_attestation_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtime_attestation_change" },
          "default": []
        },
        "sandbox_policy_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/sandbox_policy_change" },
          "default": []
        }
      }
    },
    "async_proof_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "enum": ["async_proof"] },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "generic_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "proof_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "enum": ["proof_coverage"] },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "recursive_proof_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "enum": ["recursive_proof"] },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "boundary_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "enum": ["boundary_contract"] },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "subset_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "enum": ["trusted_subset"] },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "policy_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "capability_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "added": {
          "type": "array",
          "items": { "type": "string", "maxLength": 256 },
          "default": []
        },
        "removed": {
          "type": "array",
          "items": { "type": "string", "maxLength": 256 },
          "default": []
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "budget_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["budget", "policy_limit", "arch_profile", "scope", "run_cap"]
        },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "world_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["world", "arch_node_world", "project_profile_world"]
        },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "runtime_attestation_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "sandbox_policy_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "capsule_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "subject", "path", "before", "after"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "severity": { "$ref": "#/$defs/review_severity" },
        "subject": { "type": "string", "minLength": 1, "maxLength": 256 },
        "path": { "type": ["string", "null"], "maxLength": 4096 },
        "before": { "$ref": "#/$defs/json_value" },
        "after": { "$ref": "#/$defs/json_value" },
        "ptr_before": { "type": ["string", "null"], "maxLength": 4096 },
        "ptr_after": { "type": ["string", "null"], "maxLength": 4096 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 },
          "default": []
        }
      }
    },
    "file_diff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "status",
        "before_sha256_hex",
        "after_sha256_hex",
        "changes",
        "truncated"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "status": { "type": "string", "minLength": 1, "maxLength": 128 },
        "before_sha256_hex": {
          "anyOf": [{ "$ref": "#/$defs/sha256_hex" }, { "type": "null" }]
        },
        "after_sha256_hex": {
          "anyOf": [{ "$ref": "#/$defs/sha256_hex" }, { "type": "null" }]
        },
        "changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/json_value" },
          "default": []
        },
        "module": {
          "anyOf": [{ "$ref": "#/$defs/json_value" }, { "type": "null" }]
        },
        "truncated": { "type": "boolean" }
      }
    }
  }
}
