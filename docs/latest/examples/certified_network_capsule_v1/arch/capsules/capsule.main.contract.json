{
  "schema_version": "x07.capsule.contract@0.2.0",
  "id": "capsule.main_v1",
  "worlds_allowed": ["run-os-sandboxed"],
  "capabilities": [],
  "language": {
    "allow_unsafe": false,
    "allow_ffi": false
  },
  "input": {
    "shape": {
      "brand": "certified_network_capsule.request_v1"
    }
  },
  "output": {
    "shape": {
      "brand": "certified_network_capsule.response_v1"
    }
  },
  "error_spaces": ["certified_network_capsule.error_v1"],
  "effect_log": {
    "schema_path": "capsule.main.effect_log.json",
    "redaction": "metadata_only",
    "replay_safe": true
  },
  "replay": {
    "mode": "deterministic"
  },
  "conformance": {
    "tests": ["smoke/capsule_tcp_echo"],
    "report_path": "capsule.main.conformance.json"
  },
  "network": {
    "peer_policy_paths": ["peers/loopback_tcp_v1.peer.json"],
    "request_contract_path": null,
    "response_contract_path": null,
    "conformance_tests": ["smoke/capsule_tcp_echo"]
  }
}
