{
  "schema_version": "x07.service.manifest@0.1.0",
  "service_id": "svc_scheduled_job_v1",
  "display_name": "Svc Scheduled Job V1",
  "domain_pack": {
    "id": "svc_scheduled_job_v1",
    "display_name": "Svc Scheduled Job V1"
  },
  "cells": [
    {
      "cell_key": "primary",
      "cell_kind": "scheduled-job",
      "entry_symbol": "example.main",
      "ingress_kind": "schedule",
      "runtime_class": "native-worker",
      "scale_class": "burst-batch",
      "binding_refs": [
        "db.primary"
      ],
      "topology_group": "primary",
      "runtime": {
        "schedule": {
          "cron": "0 */6 * * *",
          "timezone": "UTC",
          "concurrency_policy": "forbid",
          "retry_limit": 3,
          "start_deadline_seconds": 600
        }
      }
    }
  ],
  "topology_profiles": [
    {
      "id": "dev",
      "target_kind": "hosted",
      "placement": "co-located",
      "notes": "single deployable for local and hosted dev"
    },
    {
      "id": "prod",
      "target_kind": "k8s",
      "placement": "split-by-cell",
      "notes": "allow independent scale later"
    }
  ],
  "resource_bindings": [
    {
      "name": "db.primary",
      "kind": "postgres",
      "required": true
    }
  ],
  "default_trust_profile": "sandboxed_service_v1"
}
