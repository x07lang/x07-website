{
  "schema_version": "x07.service.manifest@0.1.0",
  "service_id": "svc_api_cell_v1",
  "display_name": "Svc Api Cell V1",
  "domain_pack": {
    "id": "svc_api_cell_v1",
    "display_name": "Svc Api Cell V1"
  },
  "cells": [
    {
      "cell_key": "primary",
      "cell_kind": "api-cell",
      "entry_symbol": "example.main",
      "ingress_kind": "http",
      "runtime_class": "native-http",
      "scale_class": "replicated-http",
      "binding_refs": [
        "db.primary",
        "obj.documents"
      ],
      "topology_group": "primary"
    }
  ],
  "topology_profiles": [
    {
      "id": "dev",
      "target_kind": "hosted",
      "placement": "co-located",
      "notes": "single deployable for local and hosted dev"
    },
    {
      "id": "prod",
      "target_kind": "k8s",
      "placement": "split-by-cell",
      "notes": "allow independent scale later"
    }
  ],
  "resource_bindings": [
    {
      "name": "db.primary",
      "kind": "postgres",
      "required": true
    },
    {
      "name": "obj.documents",
      "kind": "s3",
      "required": false
    }
  ],
  "default_trust_profile": "sandboxed_service_v1"
}
