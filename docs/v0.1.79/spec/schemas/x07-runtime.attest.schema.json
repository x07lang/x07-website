{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-runtime.attest.schema.json",
  "title": "x07.runtime.attest@0.2.0",
  "description": "Runtime attestation emitted for `run-os-sandboxed` executions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "world",
    "sandbox_backend",
    "weaker_isolation",
    "artifact_path",
    "input_len_bytes",
    "guest_image_digest",
    "effective_policy_digest",
    "network_mode",
    "network_enforcement",
    "allow_dns",
    "allow_tcp",
    "allow_udp",
    "effective_allow_hosts",
    "effective_deny_hosts",
    "bundled_binary_digest",
    "compile_attestation_digest",
    "capsule_attestation_digests",
    "effect_log_digests",
    "outcome"
  ],
  "properties": {
    "schema_version": { "const": "x07.runtime.attest@0.2.0" },
    "world": {
      "type": "string",
      "const": "run-os-sandboxed"
    },
    "sandbox_backend": {
      "type": "string",
      "enum": ["os", "vm"]
    },
    "weaker_isolation": { "type": "boolean" },
    "artifact_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "policy_path": {
      "anyOf": [
        { "type": "string", "minLength": 1, "maxLength": 4096 },
        { "type": "null" }
      ]
    },
    "input_len_bytes": { "type": "integer", "minimum": 0 },
    "run_dir": {
      "anyOf": [
        { "type": "string", "minLength": 1, "maxLength": 4096 },
        { "type": "null" }
      ]
    },
    "guest_image_digest": {
      "anyOf": [
        { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "effective_policy_digest": {
      "anyOf": [
        { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "network_mode": {
      "type": "string",
      "enum": ["disabled", "none", "allowlist"]
    },
    "network_enforcement": {
      "type": "string",
      "enum": ["none", "vm_boundary_allowlist", "guest_allowlist", "unsupported"]
    },
    "allow_dns": { "type": "boolean" },
    "allow_tcp": { "type": "boolean" },
    "allow_udp": { "type": "boolean" },
    "effective_allow_hosts": {
      "type": "array",
      "items": { "$ref": "#/$defs/net_host" },
      "default": []
    },
    "effective_deny_hosts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 255 },
      "default": []
    },
    "bundled_binary_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "compile_attestation_digest": {
      "anyOf": [
        { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "capsule_attestation_digests": {
      "type": "array",
      "items": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
    },
    "effect_log_digests": {
      "type": "array",
      "items": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "exit_status"],
      "properties": {
        "ok": { "type": "boolean" },
        "exit_status": { "type": "integer" },
        "trap": {
          "anyOf": [
            { "type": "string", "maxLength": 65536 },
            { "type": "null" }
          ]
        }
      }
    }
  },
  "$defs": {
    "net_host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "ports"],
      "properties": {
        "host": { "type": "string", "minLength": 1, "maxLength": 255 },
        "ports": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "uniqueItems": true
        }
      }
    }
  }
}
