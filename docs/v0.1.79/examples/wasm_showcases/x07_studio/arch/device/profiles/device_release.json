{
  "schema_version": "x07.device.profile@0.1.0",
  "id": "device_release",
  "v": 1,
  "target": "desktop",
  "identity": {
    "display_name": "x07 Studio",
    "app_id": "org.x07.studio"
  },
  "version": {
    "version": "0.1.0",
    "build": 1
  },
  "security": {
    "allow_dynamic_code_loading": false
  },
  "ui": {
    "project": "frontend/x07.json",
    "web_ui_profile_id": "web_ui_release"
  },
  "backend": {
    "mode": "none"
  },
  "capabilities": {
    "network": {
      "mode": "deny_by_default",
      "allow_hosts": []
    },
    "device": {
      "clipboard": false,
      "local_kv": true,
      "notifications": false
    }
  },
  "desktop": {
    "window": {
      "width": 1280,
      "height": 800,
      "resizable": true
    },
    "package": {
      "kind": "archive",
      "format": "zip"
    }
  }
}
