{
  "schema_version": "x07.app.ops.profile@0.1.0",
  "id": "ops_release",
  "v": 1,

  "capabilities": {
    "path": "arch/app/ops/caps_release.json",
    "sha256": null
  },
  "policy_cards": [],
  "slo": {
    "path": "arch/slo/slo_min.json",
    "sha256": null
  },

  "provenance": {
    "require_attestation": true,
    "predicate_type": "https://slsa.dev/provenance/v1",
    "verify_on_serve": true,
    "verify_on_deploy": true
  },

  "deploy": {
    "strategy": "canary",
    "canary": {
      "steps": [
        { "set_weight": 5 },
        { "pause_s": 10 },
        { "analysis": { "kind": "slo.eval", "require_decision": "promote" } },
        { "set_weight": 50 },
        { "pause_s": 30 },
        { "analysis": { "kind": "slo.eval", "require_decision": "promote" } },
        { "set_weight": 100 },
        { "analysis": { "kind": "slo.eval", "require_decision": "promote" } }
      ]
    },
    "blue_green": null
  }
}
