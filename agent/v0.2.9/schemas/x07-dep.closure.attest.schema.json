{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-dep.closure.attest.schema.json",
  "title": "x07.dep.closure.attest@0.1.0",
  "description": "Digest-bound attestation for the resolved dependency closure of an X07 project.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_path",
    "manifest_digest",
    "lockfile_digest",
    "package_set_digest",
    "dependencies",
    "advisory_check"
  ],
  "properties": {
    "schema_version": { "const": "x07.dep.closure.attest@0.1.0" },
    "project_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "manifest_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "lockfile_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "package_set_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependency" },
      "default": []
    },
    "advisory_check": {
      "$ref": "#/$defs/advisory_check"
    }
  },
  "$defs": {
    "sha256_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "module_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module_id", "digest"],
      "properties": {
        "module_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "digest": { "$ref": "#/$defs/sha256_digest" }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "path",
        "package_manifest_digest",
        "module_root",
        "module_root_digest",
        "modules",
        "yanked",
        "advisories"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "package_manifest_digest": { "$ref": "#/$defs/sha256_digest" },
        "module_root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "module_root_digest": { "$ref": "#/$defs/sha256_digest" },
        "modules": {
          "type": "array",
          "items": { "$ref": "#/$defs/module_digest" },
          "default": []
        },
        "yanked": { "type": "boolean" },
        "advisories": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 128 },
          "default": []
        }
      }
    },
    "advisory_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "ok",
        "allow_yanked",
        "allow_advisories",
        "yanked",
        "advisories"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["online", "offline"]
        },
        "ok": { "type": "boolean" },
        "allow_yanked": { "type": "boolean" },
        "allow_advisories": { "type": "boolean" },
        "yanked": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "default": []
        },
        "advisories": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 512 },
          "default": []
        }
      }
    }
  }
}
