{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-peer.policy.schema.json",
  "title": "x07.peer.policy@0.1.0",
  "description": "Pinned outbound or inbound peer policy referenced by network-capable capsule contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "role",
    "host",
    "ports",
    "transport",
    "tls_mode"
  ],
  "properties": {
    "schema_version": { "const": "x07.peer.policy@0.1.0" },
    "policy_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "role": {
      "type": "string",
      "enum": ["outbound", "inbound"]
    },
    "host": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "ports": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
      "uniqueItems": true
    },
    "transport": {
      "type": "string",
      "enum": ["tcp", "udp"]
    },
    "tls_mode": {
      "type": "string",
      "enum": ["none", "tls", "mtls"]
    },
    "sni": {
      "anyOf": [
        { "type": "string", "minLength": 1, "maxLength": 255 },
        { "type": "null" }
      ]
    },
    "alpn": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 64 },
      "default": []
    },
    "ca_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024,
        "pattern": "^(?![\\\\/])(?![A-Za-z]:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
      },
      "default": []
    },
    "spki_sha256": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      },
      "default": []
    },
    "mtls_alias": {
      "anyOf": [
        { "type": "string", "minLength": 1, "maxLength": 128 },
        { "type": "null" }
      ]
    }
  }
}
